{
  "info": {
    "name": "My E-Shop API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Phase 1 JSON API over the PHP+MySQL backend. Run 'Login' first to populate {{token}}."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "List products",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
      }
    },
    {
      "name": "List products (search)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products?search=lamp",
          "host": ["{{baseUrl}}"], "path": ["products"],
          "query": [{ "key": "search", "value": "lamp" }]
        }
      }
    },
    {
      "name": "Get product by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/products/1", "host": ["{{baseUrl}}"], "path": ["products", "1"] }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"secret123\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 201) {",
            "  pm.collectionVariables.set('token', pm.response.json().token);",
            "}"
          ] }
        }
      ]
    },
    {
      "name": "Login (saves token)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email_or_username\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}" },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": { "type": "text/javascript", "exec": [
            "pm.test('got token', function () {",
            "  var j = pm.response.json();",
            "  pm.expect(j.token).to.be.a('string');",
            "  pm.collectionVariables.set('token', j.token);",
            "});"
          ] }
        }
      ]
    },
    {
      "name": "Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] }
      }
    },
    {
      "name": "Create order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"shipping_address\": \"12 Test St, Hyderabad\",\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 2 }\n  ]\n}" },
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    },
    {
      "name": "My orders",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] }
      }
    }
  ]
}
