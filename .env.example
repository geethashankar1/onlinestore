# Copy to .env to override the dev defaults baked into docker-compose.yml.
# These are LOCAL DEV credentials only — set real ones before any deployment.
DB_NAME=ecommerce_db
DB_USER=eshop
DB_PASS=eshop_pass
DB_ROOT_PASS=root_pass

# ── Authorize.Net (credit/debit card payments) ───────────────────────────
# Sign up at https://developer.authorize.net — sandbox is free.
# Get your API Login ID + Transaction Key from Account > Settings > API Credentials.
# Get your Public Client Key from Account > Settings > Manage Public Client Key.
AUTHNET_LOGIN_ID=your_api_login_id
AUTHNET_TRANS_KEY=your_transaction_key
AUTHNET_CLIENT_KEY=your_public_client_key
AUTHNET_SANDBOX=true   # set to false for live payments

# ── Razorpay (UPI / Netbanking / Wallets) ───────────────────────────────
# Sign up at https://razorpay.com — test keys available immediately.
# Get Key ID + Key Secret from Dashboard > Settings > API Keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_CURRENCY=INR   # Razorpay primarily supports INR; change if on a different plan
